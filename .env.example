# Copia este archivo a `.env` y personaliza todos los valores para tu entorno.
# Los valores son de ejemplo y deben revisarse antes de desplegar en producción.
# Obligatorio: define `SERVER_NAME` y `LEVEL_NAME` antes de iniciar el servidor.
SERVER_NAME=""
LEVEL_NAME=""
TYPE="FABRIC"
VERSION="1.21.1"
INIT_MEMORY="1G"
MAX_MEMORY="1500M"
DIFFICULTY="normal"
GAMEMODE="survival"
MAX_PLAYERS="5"
ENABLE_WHITELIST="TRUE"
VIEW_DISTANCE="8"
SIMULATION_DISTANCE="4"
ONLINE_MODE="TRUE"
ENABLE_RCON="true"
# Cambia esta contraseña por una fuerte y única antes de usar RCON.
RCON_PASSWORD="REPLACE_WITH_SECURE_PASSWORD"
MODRINTH_PROJECTS="fabric-api,lithium,ferrite-core,krypton,fabric-carpet"
RESTIC_REPOSITORY="s3:s3.amazonaws.com/REPLACE_BUCKET/REPLACE_PATH"
RESTIC_PASSWORD="REPLACE_WITH_RESTIC_PASSWORD"
AWS_ACCESS_KEY_ID="REPLACE_WITH_AWS_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="REPLACE_WITH_AWS_SECRET_KEY"
AWS_DEFAULT_REGION="eu-west-1"
RESTIC_CRON_SCHEDULE="0 5 * * *"
RESTIC_CRON_LOG_PATH="/proc/1/fd/1"
RESTIC_FORGET_ARGS="--keep-daily 7 --keep-weekly 4 --prune"
RESTIC_RUN_ON_STARTUP="false"
TZ="Europe/Madrid"
